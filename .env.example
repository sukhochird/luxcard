# Base URL of the app (required for server-side API calls, e.g. on Vercel).
# Local: http://localhost:3000
# Production: https://luxcard.mn or https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Meilisearch (optional — search works without these, but with limited/no instant search).
# NEXT_PUBLIC_MEILI_HOST=https://your-meili-instance.com
# NEXT_PUBLIC_MEILI_SEARCH_KEY=your-search-api-key
